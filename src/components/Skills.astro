---
import { cv } from '../data/cv';
import Section from './Section.astro';
import Icon from './Icon.astro';
---

<Section
  id="skills"
  index="03"
  kicker="Stack técnico"
  title="Habilidades"
  intro="Herramientas con las que diseño, automatizo y aseguro infraestructura."
>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      cv.skills.map((group) => (
        <article class="reveal rounded-xl border border-line bg-surface/40 p-5 transition hover:border-accent/40">
          <div class="mb-4 flex items-center gap-3">
            <span class="grid h-9 w-9 place-items-center rounded-lg bg-accent/10 text-accent">
              <Icon name={group.icon} size={18} />
            </span>
            <h3 class="font-semibold text-ink">{group.category}</h3>
          </div>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="mono rounded-md border border-line bg-bg/50 px-2.5 py-1 text-xs text-ink-soft transition hover:border-accent/50 hover:text-accent">
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</Section>
