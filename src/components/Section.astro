---
interface Props {
  id: string;
  index: string; // «01»
  kicker: string; // etiqueta mono
  title: string;
  intro?: string;
}
const { id, index, kicker, title, intro } = Astro.props;
---

<section id={id} class="relative mx-auto w-full max-w-5xl px-5 py-20 sm:px-8 sm:py-24">
  <header class="reveal mb-12 flex flex-col gap-3">
    <div class="kicker flex items-center gap-3">
      <span class="text-accent/70">{index}</span>
      <span class="h-px w-8 bg-accent/40"></span>
      <span>{kicker}</span>
    </div>
    <h2 class="text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      {title}
    </h2>
    {intro && <p class="max-w-2xl text-ink-soft">{intro}</p>}
  </header>
  <slot />
</section>
