---
import { cv } from '../data/cv';
import Section from './Section.astro';
import Icon from './Icon.astro';
import Todo from './Todo.astro';
---

<Section
  id="experiencia"
  index="02"
  kicker="Trayectoria"
  title="Experiencia"
  intro="Una línea de tiempo en orden cronológico inverso — leída como un pipeline: cada rol es una etapa desplegada."
>
  <ol class="relative ml-3 sm:ml-4">
    <!-- Línea del pipeline -->
    <span
      class="absolute left-0 top-2 bottom-2 w-px bg-gradient-to-b from-accent via-line to-transparent"
      aria-hidden="true"></span>

    {
      cv.experience.map((job) => (
        <li class="reveal relative pl-8 pb-12 last:pb-0 sm:pl-10">
          {/* Nodo de la etapa */}
          <span
            class:list={[
              'absolute -left-[7px] top-1.5 grid h-3.5 w-3.5 place-items-center rounded-full border-2',
              job.current
                ? 'border-accent bg-accent pulse'
                : 'border-line bg-bg',
            ]}
            aria-hidden="true"
          />

          <article class="group rounded-xl border border-line bg-surface/40 p-5 transition hover:border-accent/50 sm:p-6">
            <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-2">
              <div>
                <h3 class="text-xl font-bold text-ink">{job.role}</h3>
                <p class="mt-0.5 flex flex-wrap items-center gap-2 text-ink-soft">
                  <span class="font-semibold text-accent">{job.company}</span>
                  {job.note && (
                    <span class="mono text-xs text-muted">({job.note})</span>
                  )}
                  {job.todo && <Todo label="Nombre por confirmar" />}
                </p>
              </div>
              <span
                class:list={[
                  'mono shrink-0 rounded-full px-3 py-1 text-xs',
                  job.current
                    ? 'bg-ok/15 text-ok'
                    : 'border border-line text-muted',
                ]}
              >
                {job.current && <span class="mr-1" aria-hidden="true">●</span>}
                {job.period}
              </span>
            </div>

            {job.summary && (
              <p class="mt-4 leading-relaxed text-ink-soft">{job.summary}</p>
            )}

            {job.highlights && (
              <div class="mt-5">
                <p class="kicker mb-2">Logros</p>
                <ul class="space-y-2">
                  {job.highlights.map((h) => (
                    <li class="flex gap-3 text-sm leading-relaxed text-ink-soft">
                      <Icon
                        name="check"
                        size={16}
                        class="mt-1 shrink-0 text-accent"
                      />
                      <span>{h}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {job.responsibilities && (
              <div class="mt-5">
                <p class="kicker mb-2">Responsabilidades</p>
                <ul class="space-y-2">
                  {job.responsibilities.map((r) => (
                    <li class="flex gap-3 text-sm leading-relaxed text-ink-soft">
                      <span class="mono mt-0.5 shrink-0 text-accent/70" aria-hidden="true">
                        ›
                      </span>
                      <span>{r}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {job.stack && (
              <ul class="mt-5 flex flex-wrap gap-1.5">
                {job.stack.map((t) => (
                  <li class="mono rounded border border-line bg-bg/50 px-2 py-0.5 text-[0.7rem] text-muted">
                    {t}
                  </li>
                ))}
              </ul>
            )}
          </article>
        </li>
      ))
    }
  </ol>
</Section>
